{
  "openapi": "3.0.4",
  "info": {
    "title": "Backender",
    "version": "1.0"
  },
  "paths": {
    "/api/Message/create-profile": {
      "post": {
        "tags": [
          "Message"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAccountDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAccountDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAccountDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Message/send-message": {
      "post": {
        "tags": [
          "Message"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MessageDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/MessageDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/MessageDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Message/delete-message/{id_message}": {
      "delete": {
        "tags": [
          "Message"
        ],
        "parameters": [
          {
            "name": "id_message",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "userId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Message/get-messages": {
      "get": {
        "tags": [
          "Message"
        ],
        "parameters": [
          {
            "name": "MyId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "MessageId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Message/get-all-message-by-id/{id_wanted}": {
      "get": {
        "tags": [
          "Message"
        ],
        "parameters": [
          {
            "name": "id_wanted",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Message/get-message-by-namemsg/{msg}": {
      "get": {
        "tags": [
          "Message"
        ],
        "parameters": [
          {
            "name": "msg",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateAccountDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "userName": {
            "type": "string",
            "nullable": true
          },
          "birthDate": {
            "type": "string",
            "format": "date"
          }
        },
        "additionalProperties": false
      },
      "MessageDTO": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "nullable": true
          },
          "idSender": {
            "type": "string",
            "nullable": true
          },
          "idReceiver": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}